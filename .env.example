# Platform Config
LAUNCH_FEE_SOL=0.3
MIN_LEVERAGE=2
MAX_LEVERAGE=100
MIN_TRADING_FEE_BPS=3
MAX_TRADING_FEE_BPS=100
GRADUATION_VOLUME=50000
DEFAULT_VIRTUAL_DEPTH=120000
