{
  "name": "hyperperp",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun run build:web && bun static.ts",
    "build:web": "rm -rf dist && bun build ./src/index.html --outdir dist --minify && mkdir -p dist/logos && cp public/logos/* dist/logos/",
    "dev:hot": "bun --hot serve.ts",
    "serve": "NODE_ENV=production PORT=3002 bun serve.ts",
    "pm2": "pm2 start ecosystem.config.cjs",
    "dev:full": "bun --hot src/index.ts",
    "build": "bun build ./src/index.html --outdir=dist --sourcemap --target=browser --minify --define:process.env.NODE_ENV='\"production\"' --env='BUN_PUBLIC_*'",
    "start": "NODE_ENV=production bun src/index.ts",
    "seed": "bun server/scripts/seed-markets.ts"
  },
  "dependencies": {
    "@solana/wallet-adapter-base": "^0.9.27",
    "@solana/wallet-adapter-react": "^0.15.39",
    "@solana/wallet-adapter-wallets": "^0.19.38",
    "@solana/web3.js": "^1.98.4",
    "framer-motion": "^12.40.0",
    "lightweight-charts": "^5.2.0",
    "react": "^19",
    "react-dom": "^19",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.0",
    "@types/bun": "latest",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "autoprefixer": "^10.5.0",
    "postcss": "^8.5.15",
    "tailwindcss": "^4.3.0"
  }
}
