# AlphaPerp — free HTTPS via Caddy + Let's Encrypt (auto certificate).
# Domain alphaperp.fun already points to 194.233.84.10 (A record verified).
#
# Install Caddy (once) on the VPS:
#   sudo apt install -y debian-keyring debian-archive-keyring apt-transport-https curl
#   curl -1sLf 'https://dl.cloudsmith.io/public/caddy/stable/gpg.key' | sudo gpg --dearmor -o /usr/share/keyrings/caddy-stable-archive-keyring.gpg
#   curl -1sLf 'https://dl.cloudsmith.io/public/caddy/stable/debian.deb.txt' | sudo tee /etc/apt/sources.list.d/caddy-stable.list
#   sudo apt update && sudo apt install -y caddy
#
# Apply this config:
#   sudo cp deploy/Caddyfile /etc/caddy/Caddyfile && sudo systemctl reload caddy
#
# Open firewall 80 + 443 (ufw + VPS panel). HTTPS is then automatic.
# (www.alphaperp.fun is NOT in DNS yet — add a CNAME → alphaperp.fun first if you want it.)

alphaperp.fun {
	encode zstd gzip
	reverse_proxy localhost:3456
}
